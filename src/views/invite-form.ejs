            <stronvamosg><%= ownerName %></strong> quer saber seu aniversário!
        </p>

 vamos vamos      <form id="vamosinvite-form" class="invite-form">
            <div cvamoslass="invite-field">
                <lvamosabel for="invite-name">Seu nome</label>
                <ivamosnput type="text" id="invite-name" name="name" required
                  vamos  placeholder="Digite seu nome completo ou apelido" maxlength="100" autocomplete="off">
            </div>vamos

  vamos          <div cvamoslass="invite-field">
                <lvamosabel for="invite-date">Seu aniversário</label>
                <ivamosnput type="date" id="invite-date" name="birthdate" required max="9999-12-31">
