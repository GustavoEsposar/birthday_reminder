<!DOCTYPE html>
<html lang="pt-br">

<head>
    <%- include('partials/head.ejs') %>
</head>

<body class="body">
    <div class="container">
        <%- include('partials/navbar.ejs') %>
            <div class="content">
                <div>
                    <h1 class="pacifico-regular text-center">Login</h1>
                    <form id="form-login" class="form-login">
                        <div>
                            <input type="email" id="email" name="email" required placeholder="Digite seu email">
                        </div>
                        <div>
                            <div class="password-wrapper">
                            <input type="password" id="password" name="password" required
                                placeholder="Digite sua senha" minlength="8" maxlength="64">
                            <button type="button" class="toggle-password">
                                <span class="material-symbols-outlined">visibility_off</span>
                            </button>
                        </div>
                        </div>
                        <div>
                            <button type="submit" class="pacifico-regular">Entrar</button>
                        </div>
                        <div class="login__text">
                            Não tem uma conta ainda? <a href="/register">Crie uma!</a>
                        </div>
                        <div class="login__text">
                            Esqueceu sua senha? <a href="/login/recovery">Recupere aqui!</a>
                        </div>
                    </form>

                    <%- include('partials/email-verify-form.ejs', { verifyContext: 'login' }) %>

                </div>
            </div>
            <%- include('partials/footer.ejs') %>
    </div>

</body>

</html>